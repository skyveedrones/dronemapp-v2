{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmitOnError": false
  },
  "include": [
    "server/**/*.ts", 
    "shared/**/*.ts"
  ],
  "exclude": [
    "node_modules", 
    "client", 
    "**/*.test.ts", 
    "**/*.spec.ts", 
    "vite.config.ts"
  ]
}
